---
/**
 * ParticleHero — Vanta.js NET constellation effect
 * Full-viewport animated background behind the hero section
 */
---

<div id="vanta-bg"></div>

<script>
  // Dynamic import to avoid SSR issues
  async function initVanta() {
    try {
      const THREE = await import('three');
      const { default: NET } = await import('vanta/dist/vanta.net.min');
      
      const el = document.getElementById('vanta-bg');
      if (!el) return;

      // Destroy previous instance on re-navigation (Astro View Transitions)
      if ((window as any).__vantaEffect) {
        (window as any).__vantaEffect.destroy();
      }

      (window as any).__vantaEffect = NET({
        el,
        THREE,
        mouseControls: true,
        touchControls: true,
        gyroControls: false,
        minHeight: 200.00,
        minWidth: 200.00,
        scale: 1.00,
        scaleMobile: 1.00,
        color: 0x3b82f6,           // Blue connection lines
        backgroundColor: 0x0d1117, // GitHub dark bg
        points: 14.00,
        maxDistance: 22.00,
        spacing: 18.00,
        showDots: true,
      });

      // Fade out on scroll for smooth content transition
      let ticking = false;
      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            const heroH = window.innerHeight;
            const opacity = Math.max(0, 1 - scrollY / (heroH * 0.8));
            el.style.opacity = String(opacity);
            ticking = false;
          });
          ticking = true;
        }
      });
    } catch (e) {
      console.warn('Vanta.js init skipped:', e);
    }
  }

  // Run on load and on Astro page transitions
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initVanta);
  } else {
    initVanta();
  }
  document.addEventListener('astro:page-load', initVanta);
</script>

<style>
  #vanta-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    transition: opacity 0.1s ease-out;
  }
</style>
